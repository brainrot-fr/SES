    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
